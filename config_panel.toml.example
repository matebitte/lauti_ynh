#:schema https://github.com/YunoHost/apps/raw/main/schemas/config_panel.v1.schema.json

version = "1.0"

[main]
name.en = "Lauti configuration"
name.de = "Lauti-Konfiguration"
services = ["__APP__"]

    [main.general]
    name.en = "General settings"
    name.de = "Allgemeine Einstellungen"

        [main.general.base_url]
        ask.en = "Base URL"
        ask.de = "Basis-URL"
        type = "url"
        bind = "settings"
        help.en = "The public URL where Lauti is accessible. Automatically set during installation."
        help.de = "Die öffentliche URL, unter der Lauti erreichbar ist. Wird bei der Installation automatisch gesetzt."
        readonly = true

        [main.general.locale]
        ask.en = "Locale"
        ask.de = "Locale"
        type = "select"
        choices = ["en_US", "de_DE"]
        default = "en_US"
        bind = "null"
        help.en = "Default language and date format for the website."
        help.de = "Standardsprache und Datumsformat für die Website."

        [main.general.timezone]
        ask.en = "Timezone"
        ask.de = "Zeitzone"
        type = "select"
        choices = ["UTC", "Europe/Berlin", "Europe/Paris", "Europe/London", "America/New_York", "America/Chicago", "America/Los_Angeles", "Asia/Tokyo", "Australia/Sydney"]
        default = "Europe/Berlin"
        bind = "null"
        help.en = "Timezone used for displaying dates and times."
        help.de = "Zeitzone für die Anzeige von Datum und Uhrzeit."

        [main.general.log_level]
        ask.en = "Log level"
        ask.de = "Log level"
        type = "select"
        choices = ["debug", "info", "warn", "error"]
        default = "info"
        bind = "null"
        help.en = "Verbosity of application logs. 'debug' is useful for troubleshooting."
        help.de = "Ausführlichkeit der Anwendungsprotokolle. 'debug' ist nützlich für die Fehlersuche."

    [main.maps]
    name.en = "Maps & analytics"
    name.de = "Karten & Analyse"
    optional = true

        [main.maps.osm_tile_server]
        ask.en = "OSM tile server"
        ask.de = "OSM-Tile-Server"
        type = "url"
        bind = "null"
        default = ""
        example = "https://tile.openstreetmap.org/{z}/{x}/{y}.png"
        help.en = "Custom OpenStreetMap tile server URL. Leave empty for default."
        help.de = "Benutzerdefinierte OpenStreetMap-Tile-Server-URL. Leer lassen für Standard."

        [main.maps.plausible_host]
        ask.en = "Plausible host"
        ask.de = "Plausible-Host"
        type = "url"
        bind = "null"
        default = ""
        example = "https://plausible.io"
        help.en = "Your Plausible analytics server URL. Leave empty to disable analytics."
        help.de = "URL Ihres Plausible-Analyse-Servers. Leer lassen, um die Analyse zu deaktivieren."

        [main.maps.plausible_domain]
        ask.en = "Plausible domain"
        ask.de = "Plausible-Domain"
        type = "string"
        bind = "null"
        default = ""
        example = "example.com"
        help.en = "Domain name configured in Plausible for this site."
        help.de = "Domain-Name, der in Plausible für diese Seite konfiguriert ist."
